<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/LightBackgroud"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".user.donhang.UserDonHangActivity">

    <!-- 1. Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/tb_don_hang"
        android:background="@color/white"
        app:navigationIconTint = "@color/black"
        app:navigationIcon="@drawable/ic_quay_lai"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@android:color/transparent"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize">

        <TextView
            android:id="@+id/tv_toolbar_trang_thai_don_hang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông tin đơn hàng"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:id="@+id/ll_don_hang_thanh_dieu_huong_khung_chua"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tb_don_hang">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tl_don_hang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            app:tabMode="scrollable"
            app:tabIndicatorColor="@color/ButtonOnBackgroud"
            app:tabSelectedTextColor="@color/ButtonOnBackgroud"
            app:tabTextColor="@color/black">
            <com.google.android.material.tabs.TabItem
                android:text="chờ xác nhận"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>
            <com.google.android.material.tabs.TabItem
                android:text="chờ lấy hàng"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>
            <com.google.android.material.tabs.TabItem
                android:text="đang giao hàng"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>
            <com.google.android.material.tabs.TabItem
                android:text="đã giao hàng"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>
            <com.google.android.material.tabs.TabItem
                android:text="đã huỷ"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>
        </com.google.android.material.tabs.TabLayout>

    </LinearLayout>

    <!-- 2. RecyclerView (Danh sách Đơn hàng) -->
    <LinearLayout
        app:layout_constraintTop_toBottomOf="@+id/ll_don_hang_thanh_dieu_huong_khung_chua"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_don_hang"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_thong_bao_gio_hang"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Không có đơn hàng nào"
        android:textColor="@color/gray"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_don_hang_thanh_dieu_huong_khung_chua" />


</androidx.constraintlayout.widget.ConstraintLayout>
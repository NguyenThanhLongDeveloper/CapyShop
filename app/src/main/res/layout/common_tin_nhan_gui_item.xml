<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:background="@color/LightBackgroud"
    android:orientation="vertical"
    android:padding="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="64dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tv_noi_dung_tin_nhan_gui"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chào bạn, mình muốn hỏi về tình trạng đơn hàng #DH12345 của mình. Khi nào thì giao tới nơi nhỉ?"
                android:textColor="@color/black"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_thoi_gian_tin_nhan_gui"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="09:42 AM"
            android:textColor="@color/gray"
            android:textSize="10sp" />

    </LinearLayout>

</LinearLayout>